<!DOCTYPE html>
<html>
<head>
    <title>GHUMANTE Admin Panel</title>
</head>
<body>

<h1>GHUMANTE Admin Panel</h1>

<form id="hotelForm">

    <input
        type="text"
        id="hotelName"
        placeholder="Hotel Name"
        required
    >

    <input
        type="text"
        id="location"
        placeholder="Location"
        required
    >

    <input
        type="text"
        id="price"
        placeholder="Price"
        required
    >

    <button type="submit">
        Add Hotel
    </button>

</form>

</body>
</html>
